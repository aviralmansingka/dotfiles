#!/usr/bin/env bash
set -euo pipefail

case_name="${1:-agent-keymaps}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

find_nvim() {
  if command -v nvim >/dev/null 2>&1; then
    command -v nvim
    return 0
  fi
  local bob_nvim="$HOME/.local/share/bob/nightly/bin/nvim"
  if [[ -x "$bob_nvim" ]]; then
    printf '%s\n' "$bob_nvim"
    return 0
  fi
  local bob_stable="$HOME/.local/share/bob/v0.12.2/bin/nvim"
  if [[ -x "$bob_stable" ]]; then
    printf '%s\n' "$bob_stable"
    return 0
  fi
  return 1
}

nvim_bin="$(find_nvim || true)"
if [[ -z "$nvim_bin" ]]; then
  echo "verify-nvim: nvim not found on PATH or in ~/.local/share/bob" >&2
  exit 127
fi

cd "$repo_root"

if [[ "$case_name" == "sidekick-pi-tmux" ]]; then
  if ! command -v tmux >/dev/null 2>&1; then
    echo "verify-nvim: tmux is required for sidekick-pi-tmux" >&2
    exit 127
  fi

  suffix="$(printf '%x' "$$")"
  slug="verify-${suffix}"
  session_name="pi-${slug} ${suffix}"
  label="pi-${slug}"
  sentinel="PI_VERIFY_SENTINEL_${suffix}"
  branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [[ -z "$branch" || "$branch" == "HEAD" ]]; then
    branch="verify-branch"
  fi

  cleanup() {
    tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
  }
  trap cleanup EXIT
  cleanup

  tmux new-session -d -s "$session_name" -c "$repo_root" \
    "printf '%s\\n' '$sentinel'; exec sleep 300"
  session_id="$(tmux display-message -p -t "$session_name" '#{session_id}')"
  tmux set-environment -t "$session_id" SIDEKICK_BRANCH "$branch"

  VERIFY_NVIM_CASE="$case_name" \
  VERIFY_NVIM_TMUX_LABEL="$label" \
  VERIFY_NVIM_TMUX_BRANCH="$branch" \
  VERIFY_NVIM_TMUX_SENTINEL="$sentinel" \
    "$nvim_bin" --headless '+luafile scripts/verify-nvim.lua' '+qa'
  exit $?
fi

VERIFY_NVIM_CASE="$case_name" "$nvim_bin" --headless \
  '+luafile scripts/verify-nvim.lua' \
  '+qa'

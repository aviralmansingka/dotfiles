#!/usr/bin/env bash
set -euo pipefail

case_name="${1:-agent-keymaps}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

find_nvim() {
  if command -v nvim >/dev/null 2>&1; then
    command -v nvim
    return 0
  fi
  local bob_nvim="$HOME/.local/share/bob/nightly/bin/nvim"
  if [[ -x "$bob_nvim" ]]; then
    printf '%s\n' "$bob_nvim"
    return 0
  fi
  local bob_stable="$HOME/.local/share/bob/v0.12.2/bin/nvim"
  if [[ -x "$bob_stable" ]]; then
    printf '%s\n' "$bob_stable"
    return 0
  fi
  return 1
}

nvim_bin="$(find_nvim || true)"
if [[ -z "$nvim_bin" ]]; then
  echo "verify-nvim: nvim not found on PATH or in ~/.local/share/bob" >&2
  exit 127
fi

cd "$repo_root"

if [[ "$case_name" == "sidekick-herdr-live" ]]; then
  if ! command -v herdr >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    echo "verify-nvim: herdr and jq are required for sidekick-herdr-live" >&2
    exit 127
  fi
  if ! herdr status server >/dev/null 2>&1; then
    echo "verify-nvim: a running Herdr server is required for sidekick-herdr-live" >&2
    exit 1
  fi
  if [[ ! -f "$HOME/.config/herdr/config.toml" ]] \
    || ! grep -q '^delivery = "system"$' "$HOME/.config/herdr/config.toml" \
    || ! grep -q '^enabled = true$' "$HOME/.config/herdr/config.toml"; then
    echo "verify-nvim: Herdr system notifications and sound must be enabled" >&2
    exit 1
  fi
  integration_status="$(herdr integration status)"
  if ! grep -q '^pi: current ' <<<"$integration_status" \
    || ! grep -q '^codex: current ' <<<"$integration_status"; then
    echo "verify-nvim: current Pi and Codex Herdr integrations are required" >&2
    exit 1
  fi

  suffix="$(printf '%x' "$$")"
  label="pi-verify-${suffix}"
  sentinel="HERDR_VERIFY_SENTINEL_${suffix}"

  cleanup() {
    pane_id="$(herdr agent list 2>/dev/null | jq -r --arg name "$label" '.result.agents[]? | select(.name == $name) | .pane_id' | head -n 1)"
    if [[ -n "$pane_id" ]]; then
      herdr pane close "$pane_id" >/dev/null 2>&1 || true
    fi
  }
  trap cleanup EXIT
  cleanup

  VERIFY_NVIM_CASE="$case_name" \
  VERIFY_NVIM_HERDR_LABEL="$label" \
  VERIFY_NVIM_HERDR_SENTINEL="$sentinel" \
    "$nvim_bin" --headless '+luafile scripts/verify-nvim.lua' '+qa'
  exit $?
fi

VERIFY_NVIM_CASE="$case_name" "$nvim_bin" --headless \
  '+luafile scripts/verify-nvim.lua' \
  '+qa'

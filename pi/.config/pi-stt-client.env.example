# Add these values to the bare-metal Telegram service environment during the pilot.
PI_STT_URL=http://STT_VM_PRIVATE_IP:8767/transcribe
PI_STT_TOKEN=
PI_STT_TIMEOUT_SECONDS=300

# The existing Telegram command hook should call the client without changing the daemon.
PI_TELEGRAM_VOICE_TRANSCRIPTION_PROVIDER=command
PI_TELEGRAM_VOICE_TRANSCRIPTION_CMD=$HOME/bin/pi-stt-client.py {file}

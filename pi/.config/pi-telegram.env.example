# Copy to ~/.config/pi-telegram.env and fill in per-machine values.
# Create a bot with @BotFather, then put the token here.
PI_TELEGRAM_BOT_TOKEN=123456789:replace-with-bot-token

# Comma-separated allowlist. Prefer numeric chat IDs. Usernames also work as @username.
# Send "!pi" to the bot once, then check: journalctl --user -u pi-telegram.service -f
PI_TELEGRAM_ALLOWED_CHATS=123456789

# Leave empty to send every allowlisted message to Pi.
PI_TELEGRAM_PREFIX=!pi

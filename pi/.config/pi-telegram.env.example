# Copy to ~/.config/pi-telegram.env and fill in per-machine values.
# Create a bot with @BotFather, then put the token here.
PI_TELEGRAM_BOT_TOKEN=123456789:replace-with-bot-token

# Comma-separated allowlist. Prefer numeric chat IDs. Usernames also work as @username.
# Send "!pi" to the bot once, then check: journalctl --user -u pi-telegram.service -f
PI_TELEGRAM_ALLOWED_CHATS=123456789

# Leave empty to send every allowlisted message to Pi.
# For voice notes, "!pi ..." and spoken "pi ..." both work when this is !pi.
PI_TELEGRAM_PREFIX=!pi

# Model used for Telegram replies.
PI_TELEGRAM_MODEL=openai-codex/gpt-5.5

# Optional voice-note transcription.
# Easiest: set an OpenAI-compatible API key; voice notes are sent to /audio/transcriptions.
# PI_TELEGRAM_OPENAI_API_KEY=sk-...
# PI_TELEGRAM_OPENAI_API_BASE=https://api.openai.com/v1
# PI_TELEGRAM_OPENAI_TRANSCRIBE_MODEL=whisper-1

# Or provide a local command that prints the transcript to stdout.
# Supported placeholders: {file}, {path}, {mime}, {filename}. If no placeholder is
# present, the downloaded Telegram audio file path is appended to the command.
# PI_TELEGRAM_VOICE_TRANSCRIPTION_CMD="python3 /path/to/transcribe_audio.py {file}"

# auto = command when PI_TELEGRAM_VOICE_TRANSCRIPTION_CMD is set, otherwise OpenAI
# when OPENAI_API_KEY/PI_TELEGRAM_OPENAI_API_KEY is set. Use none to disable.
PI_TELEGRAM_VOICE_TRANSCRIPTION_PROVIDER=auto
PI_TELEGRAM_MAX_AUDIO_BYTES=20971520

# Telegram typing indicator refresh interval while Pi is generating a response.
# Set to 0 to disable.
PI_TELEGRAM_TYPING_INTERVAL_SECONDS=4

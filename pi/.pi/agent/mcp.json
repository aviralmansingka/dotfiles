{
  "mcpServers": {
    "google_workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--single-user",
        "--tools",
        "sheets",
        "forms",
        "gmail"
      ],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "",
        "GOOGLE_OAUTH_CLIENT_SECRET": "",
        "GOOGLE_OAUTH_REDIRECT_URI": "http://localhost:8000/oauth2callback",
        "OAUTHLIB_INSECURE_TRANSPORT": "1",
        "USER_GOOGLE_EMAIL": "aviralmansingka@gmail.com"
      }
    },
    "whatsapp": {
      "command": "bash",
      "args": [
        "-lc",
        "cd ~/projects/whatsapp-mcp/whatsapp-mcp-server && exec uv run main.py"
      ]
    },
    "granola": {
      "command": "npx",
      "args": [
        "-y",
        "granola-mcp-plus"
      ]
    }
  }
}
